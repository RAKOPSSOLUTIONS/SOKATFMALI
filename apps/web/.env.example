# Base URL of the Next.js API (apps/api). Exposed to the browser (PUBLIC_).
# Injected at BUILD time — rebuild the front after changing it.
#   Local dev : http://localhost:3001
#   Production: https://sokatf.com   (same-origin; nginx proxies /api -> backend)
PUBLIC_API_URL="http://localhost:3001"

# Optional — Google Analytics 4. Leave empty to disable. Ex: G-XXXXXXXXXX
# (injected at build time — rebuild the front after changing it)
PUBLIC_GA_ID=""

# Optional — Google Search Console verification token (meta tag content).
PUBLIC_GSC_VERIFICATION=""
