---
import { nav, site } from "../data/site";
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="fixed top-0 inset-x-0 z-50 bg-[#f7f9fb]/90 backdrop-blur-md border-b border-line">
  <nav class="container-max flex justify-between items-center h-20">
    <a href="/" class="flex items-center shrink-0" aria-label={`${site.name} — Accueil`}>
      <img src="/img/brand/sokatf-black.png" alt={site.name} width="687" height="89" class="h-8 w-auto" />
    </a>

    <div class="hidden lg:flex items-center gap-6">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm font-semibold transition-colors pb-1",
              isActive(item.href)
                ? "text-gold-deep border-b-2 border-gold-deep"
                : "text-ink-soft hover:text-navy-900",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-4">
      <span class="hidden lg:block text-sm font-semibold text-navy-900">FR</span>
      <a href="/contact" class="btn-gold !px-5 !py-2.5">Contactez-nous</a>
      <button type="button" class="lg:hidden h-10 w-10 grid place-items-center text-navy-900" aria-label="Menu" data-menu-toggle>
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div class="lg:hidden hidden border-t border-line bg-[#f7f9fb]" data-menu-panel>
    <div class="flex flex-col px-5 py-4 gap-1">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm font-semibold px-4 py-3 rounded-md",
              isActive(item.href)
                ? "bg-navy-800/5 text-gold-deep"
                : "text-ink-soft hover:bg-navy-800/5",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a href="/contact" class="btn-gold mt-2">Contactez-nous</a>
    </div>
  </div>
</header>
<!-- spacer for fixed header -->
<div class="h-20"></div>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const panel = document.querySelector("[data-menu-panel]");
  toggle?.addEventListener("click", () => panel?.classList.toggle("hidden"));
</script>
