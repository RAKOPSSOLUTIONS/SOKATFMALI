---
import { site } from "../data/site";
const href = `${site.whatsappLink}?text=${encodeURIComponent(
  "Bonjour SOKATF SARL, je souhaite un renseignement / une cotation.",
)}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Discuter sur WhatsApp"
  class="fixed bottom-5 right-5 z-50 h-14 w-14 rounded-full grid place-items-center bg-[#25D366] text-white shadow-xl hover:scale-105 transition-transform"
>
  <span class="absolute inline-flex h-full w-full rounded-full bg-[#25D366] opacity-40 animate-ping"></span>
  <svg class="relative h-7 w-7" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
    <path d="M16.003 3C9.38 3 4 8.38 4 15c0 2.34.67 4.52 1.83 6.36L4 29l7.82-1.79A11.9 11.9 0 0 0 16 27c6.62 0 12-5.38 12-12S22.62 3 16.003 3zm0 21.8c-1.9 0-3.68-.52-5.2-1.42l-.37-.22-3.9.89.83-3.8-.24-.39A9.76 9.76 0 0 1 6.2 15c0-5.4 4.4-9.8 9.8-9.8 5.4 0 9.8 4.4 9.8 9.8s-4.4 9.8-9.797 9.8zm5.37-7.34c-.29-.15-1.72-.85-1.99-.95-.27-.1-.46-.15-.66.15-.2.29-.76.95-.93 1.14-.17.2-.34.22-.63.07-.29-.15-1.23-.45-2.34-1.44-.86-.77-1.44-1.72-1.61-2.01-.17-.29-.02-.45.13-.6.13-.13.29-.34.44-.51.15-.17.2-.29.29-.49.1-.2.05-.37-.02-.51-.07-.15-.66-1.59-.9-2.18-.24-.57-.48-.49-.66-.5l-.56-.01c-.2 0-.51.07-.78.37-.27.29-1.02 1-1.02 2.43 0 1.43 1.04 2.82 1.19 3.01.15.2 2.06 3.15 5 4.42.7.3 1.24.48 1.67.62.7.22 1.34.19 1.84.12.56-.08 1.72-.7 1.96-1.38.24-.68.24-1.26.17-1.38-.07-.12-.27-.19-.56-.34z" />
  </svg>
</a>
