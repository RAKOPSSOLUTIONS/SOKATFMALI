---
import BaseLayout from "../layouts/BaseLayout.astro";
import { IMG } from "../data/stitch";

const stats = [
  { value: "15+", label: "Années d'Expérience" },
  { value: "500+", label: "Collaborateurs" },
  { value: "24/7", label: "Opérations" },
  { value: "100%", label: "Engagement Local" },
];
const timeline = [
  { year: "2008", icon: "history", title: "Fondation", body: "Naissance de SOKATF SARL avec une vision claire : transformer le paysage industriel malien par l'excellence." },
  { year: "2015", icon: "trending_up", title: "Expansion Diversifiée", body: "Lancement de nouvelles filiales stratégiques dans les secteurs clés de l'économie, consolidant notre position de leader." },
  { year: "2024", icon: "public", title: "Leadership Regional", body: "SOKATF SARL devient un acteur incontournable en Afrique de l'Ouest, portant haut les couleurs du savoir-faire malien." },
];
const dirigeant = [
  "Depuis notre création, notre boussole a toujours été l'impact positif que nous pouvons avoir sur notre nation. Le Mali regorge de talents et d'opportunités, et SOKATF SARL se veut le catalyseur de ce potentiel industriel.",
  "Notre stratégie repose sur trois piliers fondamentaux : la rigueur dans l'exécution, l'innovation constante et le respect de nos engagements envers nos partenaires et clients. Nous ne construisons pas seulement des infrastructures ou des produits, nous bâtissons la confiance.",
  "Chaque projet que nous entreprenons est une pierre ajoutée à l'édifice d'une Afrique forte et prospère. Je suis fier de diriger une équipe qui partage cette passion pour l'excellence et cette soif de dépassement.",
];
---

<BaseLayout title="À Propos" description="La vision de SOKATF SARL pour l'émergence industrielle du Mali : histoire, mission, valeurs et leadership.">
  <!-- Hero -->
  <section class="relative h-[560px] flex items-center overflow-hidden">
    <img src={IMG.aproposHero} alt="Complexe industriel moderne au Mali au coucher du soleil" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/90 via-navy-900/60 to-transparent"></div>
    <div class="container-max relative z-10">
      <div class="max-w-2xl">
        <span class="inline-block px-3 py-1 rounded bg-white/10 backdrop-blur text-gold-soft text-[12px] font-bold uppercase tracking-widest mb-6">Vision Industrielle</span>
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-white mb-6 text-balance">Notre Vision pour l'Émergence du Mali</h1>
        <p class="text-lg text-slate-200 leading-relaxed mb-8 max-w-xl">
          Placer le commerce général au service de tous les secteurs stratégiques du Mali, avec excellence opérationnelle et engagement indéfectible envers le développement national.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/projets" class="btn-gold">Nos Réalisations</a>
          <a href="/services" class="btn-outline-white">En savoir plus</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats band (overlapping) -->
  <section class="container-max">
    <div class="bg-navy-800 rounded-xl shadow-xl -mt-16 relative z-20 grid grid-cols-2 md:grid-cols-4 gap-8 p-10 md:p-12">
      {
        stats.map((s) => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-extrabold text-gold-soft">{s.value}</div>
            <div class="text-[12px] uppercase tracking-widest text-slate-400 mt-2">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Timeline -->
  <section class="section container-max">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-navy-900">Notre Histoire</h2>
      <div class="w-16 h-1 bg-gold mx-auto mt-4"></div>
    </div>
    <div class="relative max-w-4xl mx-auto">
      <div class="hidden md:block absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px bg-line"></div>
      <div class="space-y-10">
        {
          timeline.map((t, i) => (
            <div class:list={["relative md:grid md:grid-cols-2 md:gap-12 items-center", i % 2 === 1 && "md:[direction:rtl]"]}>
              <div class:list={["card p-7", i % 2 === 1 && "md:[direction:ltr]"]}>
                <div class="text-gold-deep font-extrabold text-xl mb-1">{t.year}</div>
                <h3 class="text-lg font-bold text-navy-900 mb-2">{t.title}</h3>
                <p class="text-sm text-ink-soft leading-relaxed">{t.body}</p>
              </div>
              <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 h-11 w-11 rounded-full bg-navy-800 text-gold-soft items-center justify-center ring-4 ring-[#f7f9fb]">
                <span class="material-symbols-outlined text-[20px]">{t.icon}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Le Mot du Dirigeant -->
  <section class="section bg-[#eceef0]">
    <div class="container-max grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <img src={IMG.dirigeantPortrait} alt="Portrait du Directeur Général de SOKATF SARL" class="w-full h-[520px] object-cover rounded-lg shadow-xl" />
        <div class="hidden md:block absolute -bottom-6 -right-6 bg-white rounded-lg p-6 shadow-xl max-w-xs">
          <p class="text-sm italic text-ink mb-3">"L'excellence n'est pas un acte, mais une habitude que nous cultivons chaque jour chez SOKATF."</p>
          <div class="font-bold text-navy-900 text-sm">Directeur Général</div>
          <div class="text-gold-deep text-sm font-semibold">SOKATF SARL</div>
        </div>
      </div>
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-6">Le Mot du Dirigeant</h2>
        {dirigeant.map((p) => <p class="text-ink-soft leading-relaxed mb-5">{p}</p>)}
        <img src={IMG.signature} alt="Signature du Directeur Général" class="h-14 mt-4 opacity-80" />
      </div>
    </div>
  </section>

  <!-- Mission & Valeurs -->
  <section class="section container-max">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-3">Notre Mission & Valeurs</h2>
      <p class="text-ink-soft max-w-2xl mx-auto">Les principes qui guident chacune de nos décisions et forgent notre identité institutionnelle.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      <!-- Mission -->
      <div class="reveal md:col-span-7 card p-9 border-t-4 border-t-navy-800">
        <span class="material-symbols-outlined text-4xl text-navy-800 mb-5">rocket_launch</span>
        <h3 class="text-xl font-bold text-navy-900 mb-3">Notre Mission</h3>
        <p class="text-ink-soft leading-relaxed mb-6">
          Faire du commerce général le moteur de l'économie malienne : importer, distribuer et approvisionner
          l'ensemble des secteurs stratégiques avec les plus hauts standards de qualité, de fiabilité et de disponibilité.
        </p>
        <a href="/services" class="link-gold">Explorer nos secteurs <span class="material-symbols-outlined text-[18px]">arrow_forward</span></a>
      </div>
      <!-- Intégrité -->
      <div class="reveal md:col-span-5 rounded-lg bg-navy-800 text-white p-9">
        <span class="material-symbols-outlined fill text-4xl text-gold-soft mb-5">verified_user</span>
        <h3 class="text-xl font-bold mb-3">Intégrité</h3>
        <p class="text-slate-300 leading-relaxed">La transparence et l'éthique sont au cœur de toutes nos relations d'affaires. Nous honorons nos contrats et nos promesses sans compromis.</p>
      </div>
      <!-- Innovation -->
      <div class="reveal md:col-span-4 card p-9 border-l-4 border-l-gold">
        <span class="material-symbols-outlined text-4xl text-gold-deep mb-5">lightbulb</span>
        <h3 class="text-xl font-bold text-navy-900 mb-3">Innovation</h3>
        <p class="text-ink-soft leading-relaxed">Nous investissons massivement dans la recherche et les nouvelles technologies pour rester à la pointe de l'industrie.</p>
      </div>
      <!-- Impact Social -->
      <div class="reveal md:col-span-8 relative rounded-lg overflow-hidden min-h-[240px] group">
        <img src={IMG.impactSocial} alt="Travailleurs maliens sur un site industriel" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
        <div class="absolute inset-0 bg-gradient-to-t from-navy-900/90 to-navy-900/30"></div>
        <div class="absolute inset-0 p-9 flex flex-col justify-end">
          <h3 class="text-xl font-bold text-white mb-2">Impact Social</h3>
          <p class="text-slate-200 max-w-lg">Plus qu'une entreprise, SOKATF est un partenaire social. Nous soutenons activement les communautés locales par l'éducation et l'emploi durable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section container-max">
    <div class="card text-center max-w-3xl mx-auto p-12">
      <h2 class="text-3xl font-bold text-navy-900 mb-4 text-balance">Rejoignez notre dynamique de croissance</h2>
      <p class="text-ink-soft mb-8">Partenariats stratégiques, opportunités de carrière ou projets industriels : bâtissons ensemble l'excellence.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/partenaires" class="btn-navy">Devenir Partenaire</a>
        <a href="/contact" class="btn-outline">Consulter les Offres</a>
      </div>
    </div>
  </section>
</BaseLayout>
