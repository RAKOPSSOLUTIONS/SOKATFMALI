---
import BaseLayout from "../layouts/BaseLayout.astro";
import { IMG } from "../data/stitch";
import { homeProjects } from "../data/projects";
import { site } from "../data/site";
import { valueChain } from "../data/commerce";
import { getSiteContent } from "../data/content";

const apiUrl = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3001";
const c = await getSiteContent();

// Homepage service cards: first one spans wider and is highlighted as core.
const homeServices = c.services.map((s, i) => ({ ...s, span: i === 0 ? "lg:col-span-2" : "", core: i === 0 }));
const smallTiles = [
  { label: "Énergie", icon: "solar_power" },
  { label: "Forage", icon: "water_drop" },
  { label: "Matériel Médical", icon: "medical_services" },
  { label: "Industrie", icon: "factory" },
];
const stats = c.stats;
const partners = c.partners;
---

<BaseLayout>
  <!-- ===== Hero ===== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">
    <img src={IMG.heroHome} alt="Complexe industriel de SOKATF SARL au Mali au crépuscule" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/90 via-navy-900/70 to-navy-900/30"></div>
    <div class="container-max relative z-10 py-24">
      <div class="max-w-3xl">
        <span class="eyebrow eyebrow-gold mb-5">{c.heroEyebrow}</span>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-[1.05] mb-6 text-balance">
          {c.heroTitle}<br /><span class="text-gold-soft">{c.heroTitleAccent}</span>
        </h1>
        <p class="text-lg text-slate-200/90 max-w-xl mb-9 leading-relaxed">
          {c.heroSubtitle}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/services" class="btn-gold">Nos Services <span class="material-symbols-outlined text-[18px]">arrow_forward</span></a>
          <a href="/a-propos" class="btn-outline-white">Découvrir le Groupe</a>
        </div>
      </div>
    </div>
    <div class="hidden lg:flex absolute bottom-10 right-12 z-10 gap-10">
      <div><div class="text-3xl font-extrabold text-white">2012</div><div class="text-sm text-slate-300">Fondation</div></div>
      <div class="w-px bg-white/20"></div>
      <div><div class="text-3xl font-extrabold text-gold-soft">100%</div><div class="text-sm text-slate-300">Engagement Malien</div></div>
    </div>
  </section>

  <!-- ===== About ===== -->
  <section class="section container-max grid md:grid-cols-2 gap-16 items-center">
    <div class="reveal relative">
      <img src={IMG.aboutOffice} alt="Salle de conseil moderne à Bamako" class="w-full aspect-square object-cover rounded-lg" />
      <div class="hidden lg:block absolute -bottom-6 -right-6 bg-navy-800 text-white rounded-lg p-6 shadow-xl max-w-[220px]">
        <div class="text-4xl font-extrabold text-gold-soft">15+</div>
        <div class="text-sm text-slate-300 mt-1">Années de Leadership Industriel au Mali</div>
      </div>
    </div>
    <div class="reveal">
      <span class="eyebrow mb-3">{c.aboutEyebrow}</span>
      <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5 text-balance">{c.aboutTitle}</h2>
      <p class="text-ink-soft leading-relaxed mb-8">
        {c.aboutText}
      </p>
      <div class="space-y-6 mb-8">
        {[
          { icon: "verified", title: "Standard de Qualité International", text: "Nous appliquons les protocoles les plus stricts sur tous nos chantiers et services." },
          { icon: "groups", title: "Capital Humain National", text: "Nous valorisons et formons les talents locaux pour bâtir l'avenir du pays." },
        ].map((f) => (
          <div class="flex gap-4">
            <span class="icon-tile shrink-0"><span class="material-symbols-outlined">{f.icon}</span></span>
            <div>
              <h3 class="font-bold text-navy-900 mb-1">{f.title}</h3>
              <p class="text-sm text-ink-soft">{f.text}</p>
            </div>
          </div>
        ))}
      </div>
      <a href="/a-propos" class="link-gold">En savoir plus sur nos valeurs <span class="material-symbols-outlined text-[18px]">arrow_forward</span></a>
    </div>
  </section>

  <!-- ===== Commerce value chain ===== -->
  <section class="section bg-navy-800 text-white">
    <div class="container-max">
      <div class="text-center mb-14">
        <span class="eyebrow eyebrow-gold mb-3">Notre chaîne de valeur</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white text-balance">De l'importation à la distribution</h2>
        <p class="text-slate-400 max-w-2xl mx-auto mt-4">
          Un processus de commerce général maîtrisé de bout en bout, au service de tous les secteurs.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {
          valueChain.map((s) => (
          <div class="reveal rounded-lg border border-white/10 bg-white/5 p-7">
            <div class="flex items-center justify-between mb-5">
              <span class="text-3xl font-extrabold text-gold-soft">{s.n}</span>
              <span class="material-symbols-outlined text-gold-soft">{s.icon}</span>
            </div>
            <h3 class="font-bold mb-2">{s.t}</h3>
            <p class="text-sm text-slate-400">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== Services bento ===== -->
  <section class="section bg-[#f2f4f6]">
    <div class="container-max">
      <div class="text-center mb-14">
        <span class="eyebrow mb-3">Nos Expertises</span>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 text-balance">Le Commerce Général au Cœur de Nos Pôles</h2>
        <p class="text-ink-soft max-w-2xl mx-auto mt-4">
          Le commerce général est le fil conducteur de toutes nos activités : nous approvisionnons et servons chacun de nos secteurs.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        {
          homeServices.map((s) => (
            <a href="/services" class:list={["reveal card card-hover p-8 group", s.span, s.core && "border-t-2 border-t-gold"]}>
              <div class="flex items-center justify-between mb-6">
                <span class="icon-tile"><span class="material-symbols-outlined fill">{s.icon}</span></span>
                {s.core && <span class="text-[11px] font-bold uppercase tracking-widest text-gold-deep">Cœur de métier</span>}
              </div>
              <h3 class="text-lg font-bold text-navy-900 mb-2">{s.title}</h3>
              <p class="text-sm text-ink-soft">{s.text}</p>
            </a>
          ))
        }
        <div class="lg:col-span-2 grid grid-cols-2 gap-6">
          {
            smallTiles.map((t) => (
              <div class="reveal card p-6 flex items-center gap-4">
                <span class="material-symbols-outlined text-gold-deep text-[28px]">{t.icon}</span>
                <span class="font-semibold text-navy-900">{t.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Stats ===== -->
  <section class="bg-navy-800 py-20">
    <div class="container-max grid grid-cols-2 md:grid-cols-4 gap-12 text-center">
      {
        stats.map((s) => (
          <div>
            <span class="material-symbols-outlined text-gold-soft text-4xl mb-3">{s.icon}</span>
            <div class="text-4xl font-extrabold text-white">{s.value}</div>
            <div class="text-[13px] uppercase tracking-widest text-slate-400 mt-1">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===== Projects gallery ===== -->
  <section class="section container-max">
    <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
      <div>
        <span class="eyebrow mb-3">Réalisations</span>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 text-balance">Bâtir les Fondations du Nouveau Mali</h2>
      </div>
      <a href="/projets" class="btn-outline">Voir toute la galerie <span class="material-symbols-outlined text-[18px]">arrow_forward</span></a>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {
        homeProjects.map((p) => (
          <a href="/projets" class="reveal group relative h-96 rounded-lg overflow-hidden">
            <img src={IMG[p.img]} alt={p.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-900/90 via-navy-900/20 to-transparent"></div>
            <div class="absolute bottom-0 p-6">
              <span class="text-[12px] font-semibold uppercase tracking-widest text-gold-soft">{p.label}</span>
              <h3 class="text-xl font-bold text-white mt-1">{p.title}</h3>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ===== Testimonial + Partners ===== -->
  <section class="section bg-[#e0e3e5]">
    <div class="container-max grid lg:grid-cols-2 gap-16">
      <div class="reveal">
        <span class="eyebrow mb-4">Ils nous font confiance</span>
        <div class="card p-8 relative">
          <span class="material-symbols-outlined absolute top-6 right-6 text-6xl text-gold/30">format_quote</span>
          <div class="flex gap-1 text-gold-dim mb-5">
            {[0, 1, 2, 3, 4].map(() => <span class="material-symbols-outlined fill text-[20px]">star</span>)}
          </div>
          <p class="text-lg text-ink italic leading-relaxed mb-6">
            "SOKATF SARL a démontré une réactivité exceptionnelle sur nos sites miniers de Kayes. Leur approche
            intégrée combinant sécurité et logistique est un atout majeur pour nos opérations internationales au Mali."
          </p>
          <div class="flex items-center gap-4">
            <span class="h-12 w-12 rounded-full grid place-items-center bg-navy-800 text-gold-soft">
              <span class="material-symbols-outlined">person</span>
            </span>
            <div>
              <div class="font-bold text-navy-900">Moussa Traoré</div>
              <div class="text-sm text-ink-soft">Directeur des Opérations, Groupe Minier Global</div>
            </div>
          </div>
        </div>
      </div>
      <div class="reveal">
        <span class="eyebrow mb-4">Partenaires Stratégiques</span>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          {
            partners.map((p) => (
              <div class="card h-28 grid place-items-center text-center px-3">
                <span class="font-bold text-ink-soft tracking-wide text-sm">{p}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA + Contact form ===== -->
  <section class="section bg-navy-800 relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-gold/10 blur-3xl"></div>
    <div class="container-max relative grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-5 text-balance">Bâtissons l'avenir <span class="text-gold-soft">ensemble.</span></h2>
        <p class="text-slate-300 leading-relaxed mb-8 max-w-lg">
          Vous avez un projet d'envergure ? Vous recherchez un partenaire industriel fiable au Mali ?
          Nos experts sont à votre disposition pour transformer vos ambitions en réalités concrètes.
        </p>
        <div class="space-y-4">
          {[
            { icon: "location_on", text: site.addressShort },
            { icon: "call", text: site.phoneDisplay },
            { icon: "mail", text: site.email },
          ].map((r) => (
            <div class="flex items-center gap-4 text-slate-200">
              <span class="h-11 w-11 rounded-md grid place-items-center bg-white/5 border border-white/10 text-gold-soft">
                <span class="material-symbols-outlined text-[20px]">{r.icon}</span>
              </span>
              <span>{r.text}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-white rounded-lg p-7 md:p-8">
        <h3 class="text-xl font-bold text-navy-900 mb-6">Demande de devis / Contact</h3>
        <form id="home-form" class="space-y-4" novalidate>
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="field-label" for="h-name">Nom Complet</label>
              <input id="h-name" name="name" class="field" placeholder="Votre nom" required />
              <p class="text-[12px] text-rose-600 mt-1 hidden" data-err="name"></p>
            </div>
            <div>
              <label class="field-label" for="h-company">Entreprise</label>
              <input id="h-company" name="company" class="field" placeholder="Nom de la société" />
            </div>
          </div>
          <div>
            <label class="field-label" for="h-email">Email Professionnel</label>
            <input id="h-email" name="email" type="email" class="field" placeholder="email@entreprise.com" required />
            <p class="text-[12px] text-rose-600 mt-1 hidden" data-err="email"></p>
          </div>
          <div>
            <label class="field-label" for="h-sector">Secteur d'Activité</label>
            <select id="h-sector" name="sector" class="field">
              <option>BTP / Construction</option>
              <option>Sécurité & Gardiennage</option>
              <option>Agro-industrie</option>
              <option>Solutions IT</option>
              <option>Autre</option>
            </select>
          </div>
          <div>
            <label class="field-label" for="h-message">Message</label>
            <textarea id="h-message" name="message" rows="4" class="field" placeholder="Décrivez votre projet..." required></textarea>
            <p class="text-[12px] text-rose-600 mt-1 hidden" data-err="message"></p>
          </div>
          <div data-feedback class="hidden rounded-md px-4 py-3 text-sm text-center font-semibold"></div>
          <button type="submit" data-submit class="btn-gold w-full"><span data-submit-label>Envoyer la demande</span></button>
        </form>
      </div>
    </div>
  </section>

  <script define:vars={{ apiUrl }}>
    const form = document.getElementById("home-form");
    const fb = form.querySelector("[data-feedback]");
    const btn = form.querySelector("[data-submit]");
    const lbl = form.querySelector("[data-submit-label]");
    function clearErr() { form.querySelectorAll("[data-err]").forEach((e) => { e.textContent = ""; e.classList.add("hidden"); }); }
    function feedback(ok, msg) {
      fb.textContent = msg;
      fb.classList.remove("hidden", "bg-emerald-50", "text-emerald-700", "bg-rose-50", "text-rose-700");
      fb.classList.add(ok ? "bg-emerald-50" : "bg-rose-50", ok ? "text-emerald-700" : "text-rose-700");
    }
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearErr(); fb.classList.add("hidden");
      const payload = Object.fromEntries(new FormData(form).entries());
      payload.source = "/ (accueil)";
      btn.disabled = true; const o = lbl.textContent; lbl.textContent = "Envoi…";
      try {
        const res = await fetch(`${apiUrl}/api/quote`, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) { form.reset(); feedback(true, "Merci ! Votre demande a bien été envoyée."); }
        else if (res.status === 422 && data.errors) {
          for (const [f, m] of Object.entries(data.errors)) { const el = form.querySelector(`[data-err="${f}"]`); if (el) { el.textContent = m; el.classList.remove("hidden"); } }
          feedback(false, "Veuillez corriger les champs indiqués.");
        } else feedback(false, "Une erreur est survenue. Réessayez plus tard.");
      } catch { feedback(false, "Impossible de joindre le serveur. Vérifiez que l'API est démarrée."); }
      finally { btn.disabled = false; lbl.textContent = o; }
    });
  </script>
</BaseLayout>
