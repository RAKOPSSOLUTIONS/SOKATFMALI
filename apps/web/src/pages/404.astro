---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page introuvable">
  <section class="section container-max min-h-[62vh] flex flex-col items-center justify-center text-center">
    <span class="font-extrabold text-6xl md:text-8xl text-gold-deep">404</span>
    <h1 class="text-2xl md:text-3xl font-bold text-navy-900 mt-4 mb-3">Page introuvable</h1>
    <p class="text-ink-soft max-w-md mb-8">
      La page que vous recherchez n'existe pas ou a été déplacée.
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/" class="btn-navy">Retour à l'accueil</a>
      <a href="/commerce-general" class="btn-outline">Notre commerce général</a>
    </div>
  </section>
</BaseLayout>
