---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services } from "../data/services";
import { IMG } from "../data/stitch";
import { productCategories } from "../data/commerce";

const stats = [
  { value: "10+", label: "Pôles d'Activité" },
  { value: "500+", label: "Employés Qualifiés" },
  { value: "150+", label: "Projets Livrés" },
  { value: "98%", label: "Satisfaction Client" },
];
---

<BaseLayout title="Nos Services" description="Les dix pôles d'excellence de SOKATF SARL : commerce, BTP, sécurité, produits pétroliers, agro-business, IT et plus.">
  <!-- Hero -->
  <section class="bg-navy-800 text-white">
    <div class="container-max py-24 md:py-28 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-6 text-balance">
        Le Commerce Général<br /><span class="text-gold-soft">au Cœur de Tous les Secteurs</span>
      </h1>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto leading-relaxed">
        Cœur de métier de SOKATF SARL, le commerce général — import, distribution et négoce — se décline
        à travers dix pôles d'excellence au service du développement du Mali.
      </p>
    </div>
  </section>

  <!-- Commerce Général — feature band -->
  <section class="section bg-[#f2f4f6]">
    <div class="container-max grid lg:grid-cols-2 gap-14 items-center">
      <div>
        <span class="eyebrow mb-3">Cœur de métier</span>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5 text-balance">Le Commerce Général, notre métier fondateur</h2>
        <p class="text-ink-soft leading-relaxed mb-8">
          SOKATF SARL relie les marchés internationaux à la demande malienne. De l'achat à la livraison,
          nous maîtrisons toute la chaîne commerciale et approvisionnons l'ensemble de nos secteurs d'activité.
        </p>
        <ul class="space-y-4 mb-8">
          {[
            { icon: "flight_takeoff", t: "Importation & sourcing international" },
            { icon: "local_shipping", t: "Distribution & approvisionnement national" },
            { icon: "handshake", t: "Négoce & représentation de marques" },
            { icon: "warehouse", t: "Logistique, stockage & transport" },
          ].map((b) => (
            <li class="flex items-center gap-4">
              <span class="h-10 w-10 shrink-0 rounded-md grid place-items-center bg-navy-800 text-gold-soft">
                <span class="material-symbols-outlined text-[20px]">{b.icon}</span>
              </span>
              <span class="font-semibold text-navy-900">{b.t}</span>
            </li>
          ))}
        </ul>
        <a href="/contact" class="btn-gold">Demander un devis <span class="material-symbols-outlined text-[18px]">arrow_forward</span></a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {[
          { v: "Import / Export", l: "Négoce international", icon: "import_export" },
          { v: "Distribution", l: "Sur tout le territoire", icon: "storefront" },
          { v: "Approvisionnement", l: "Tous secteurs", icon: "inventory_2" },
          { v: "Représentation", l: "Marques & fournisseurs", icon: "verified" },
        ].map((c) => (
          <div class="rounded-lg bg-navy-800 text-white p-6">
            <span class="material-symbols-outlined text-gold-soft text-3xl mb-4">{c.icon}</span>
            <div class="font-bold">{c.v}</div>
            <div class="text-[13px] text-slate-400 mt-1">{c.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Product ranges -->
  <section class="section container-max">
    <div class="text-center mb-12">
      <span class="eyebrow mb-3">Nos gammes</span>
      <h2 class="text-3xl md:text-4xl font-bold text-navy-900 text-balance">Ce que nous commercialisons</h2>
      <p class="text-ink-soft max-w-2xl mx-auto mt-4">
        Une large gamme de biens et d'équipements importés, stockés et distribués à travers le Mali.
      </p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {
        productCategories.map((c) => (
          <div class="reveal card card-hover p-6 flex flex-col items-center text-center gap-3">
            <span class="icon-tile"><span class="material-symbols-outlined text-[26px]">{c.icon}</span></span>
            <span class="font-semibold text-navy-900 text-[15px]">{c.name}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Sectors served -->
  <section class="section bg-[#f2f4f6]">
    <div class="container-max">
    <div class="text-center mb-12">
      <span class="eyebrow mb-3">Nos pôles</span>
      <h2 class="text-3xl md:text-4xl font-bold text-navy-900 text-balance">Les secteurs que nous servons</h2>
      <p class="text-ink-soft max-w-2xl mx-auto mt-4">
        Notre commerce général irrigue chacun de ces dix pôles d'excellence au service du développement du Mali.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        services.map((s) =>
          s.featured ? (
            <div class="reveal relative lg:col-span-2 min-h-[400px] rounded-lg overflow-hidden group">
              <img src={IMG.oilRefinery} alt="Raffinerie pétrolière au coucher du soleil" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-900 via-navy-900/60 to-transparent"></div>
              <div class="absolute inset-0 p-10 flex flex-col justify-end">
                <span class="self-start px-3 py-1 rounded bg-gold-deep text-white text-[12px] font-semibold uppercase tracking-widest mb-4">Secteur Stratégique</span>
                <h3 class="text-3xl font-extrabold text-white mb-3">{s.n}. {s.title}</h3>
                <p class="text-slate-200 max-w-xl mb-6">{s.description}</p>
                <a href="/contact" class="btn-white self-start">Consulter l'offre</a>
              </div>
            </div>
          ) : (
            <a href="/contact" class:list={["reveal card card-hover p-8 flex flex-col group", s.n === 1 && "border-t-2 border-t-gold"]}>
              <div class="flex items-center justify-between mb-6">
                <span class="icon-tile"><span class="material-symbols-outlined text-[28px]">{s.icon}</span></span>
                {s.n === 1 && <span class="text-[11px] font-bold uppercase tracking-widest text-gold-deep">Cœur de métier</span>}
              </div>
              <h3 class="text-xl font-bold text-navy-900 mb-3">{s.title}</h3>
              <p class="text-ink-soft text-[15px] leading-relaxed mb-6">{s.description}</p>
              <span class="link-gold mt-auto text-sm">En savoir plus <span class="material-symbols-outlined text-[18px]">arrow_forward</span></span>
            </a>
          ),
        )
      }
    </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-navy-800 py-20">
    <div class="container-max grid grid-cols-2 lg:grid-cols-4 gap-12 text-center">
      {
        stats.map((s) => (
          <div>
            <div class="text-4xl font-extrabold text-gold-soft">{s.value}</div>
            <div class="text-[13px] uppercase tracking-widest text-slate-400 mt-2">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
