// SOKATF-SARL backend data model.
//
// Dev uses SQLite (zero-setup). To move to Postgres for production, change
// `provider` to "postgresql" and point DATABASE_URL at your instance, then
// run `pnpm --filter @sokatf/api db:push`. Note: SQLite has no native enums,
// so status/type fields are plain strings validated in application code
// (see src/lib/constants.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A contact-form message or a "request a quote" submission from the site.
model Lead {
  id        String   @id @default(cuid())
  type      String   @default("CONTACT") // CONTACT | QUOTE
  status    String   @default("NEW") // NEW | IN_PROGRESS | CLOSED
  name      String
  email     String
  phone     String?
  company   String?
  sector    String? // slug of the sector of interest
  budget    String? // free-text budget range (quotes)
  message   String
  source    String? // page/path the lead came from
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([createdAt])
}

/// A business sector shown on the public site and managed in the admin.
model Sector {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String // short one-liner for cards
  description String // longer copy for the sector detail
  icon        String   @default("business_center") // Material Symbols name
  accent      String   @default("primary") // token key: primary | secondary | tertiary-fixed-dim | error
  featured    Boolean  @default(false)
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, order])
}

/// A reference project / realisation used to build credibility.
model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  sector      String? // slug of the related sector
  description String
  imageUrl    String?
  location    String?
  year        Int?
  status      String   @default("COMPLETED") // PLANNED | IN_PROGRESS | COMPLETED
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
}

/// A commercial quotation (devis). Line items stored as JSON.
model Quote {
  id            String   @id @default(cuid())
  number        String   @unique // DEV-2026-0001
  status        String   @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED
  clientName    String
  clientCompany String?
  clientEmail   String?
  clientPhone   String?
  clientAddress String?
  date          DateTime @default(now())
  validUntil    DateTime?
  items         String   @default("[]") // JSON: [{description, quantity, unitPrice}]
  taxRate       Float    @default(18) // TVA Mali
  discount      Float    @default(0) // montant FCFA
  notes         String?
  currency      String   @default("FCFA")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// An invoice (facture). Line items stored as JSON; payments tracked separately.
model Invoice {
  id            String    @id @default(cuid())
  number        String    @unique // FAC-2026-0001
  status        String    @default("DRAFT") // DRAFT | SENT | PARTIAL | PAID | OVERDUE | CANCELLED
  quoteId       String?
  clientName    String
  clientCompany String?
  clientEmail   String?
  clientPhone   String?
  clientAddress String?
  date          DateTime  @default(now())
  dueDate       DateTime?
  items         String    @default("[]")
  taxRate       Float     @default(18)
  discount      Float     @default(0)
  notes         String?
  currency      String    @default("FCFA")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]

  @@index([status])
  @@index([createdAt])
}

/// A payment recorded against an invoice.
model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  date      DateTime @default(now())
  method    String   @default("Espèces") // Espèces | Virement | Chèque | Mobile Money
  note      String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
}

/// A back-office user with a role.
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("commercial") // admin | comptable | commercial
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A reusable client (address book) for devis/factures.
model Client {
  id        String   @id @default(cuid())
  name      String
  company   String?
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

/// An audit-trail entry recording a back-office action.
model ActivityLog {
  id        String   @id @default(cuid())
  action    String // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | STATUS | PAYMENT | EMAIL
  entity    String // Quote | Invoice | Client | User | Sector | Project | CatalogItem | Auth | Settings
  entityId  String?
  detail    String? // human-readable summary
  userEmail String?
  userName  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
}

/// A reusable product or service (catalogue) inserted as lines in devis/factures.
model CatalogItem {
  id          String   @id @default(cuid())
  kind        String   @default("PRODUCT") // PRODUCT | SERVICE
  name        String
  description String?
  imageUrl    String? // URL d'image (produit)
  unit        String   @default("unité") // unité | lot | kg | tonne | jour | mois | prestation…
  price       Float    @default(0) // prix unitaire FCFA
  reference   String? // SKU / code
  category    String? // secteur (slug) ou libellé libre
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind, active])
}

/// Singleton settings applied to devis/factures (branding & defaults).
model Setting {
  id             String   @id @default("singleton")
  companyName    String   @default("SOKATF SARL")
  logoUrl        String?
  defaultTaxRate Float    @default(18)
  paymentTerms   String? // conditions par défaut (affichées sur les documents)
  bankDetails    String? // RIB / IBAN / Mobile Money
  documentFooter String? // mention de bas de page
  notifyEmail    String? // adresse notifiée des nouveaux prospects
  quotePrefix        String  @default("Devis")
  invoicePrefix      String  @default("Facture")
  numberIncludeMonth Boolean @default(true)
  numberPadding      Int     @default(4)
  updatedAt      DateTime @updatedAt
}
