# ---------------------------------------------------------------------------
# SOKATF-SARL backend (apps/api) — copy to .env and adjust.
# ---------------------------------------------------------------------------

# Database. SQLite by default (zero-setup local dev). For Postgres in prod,
# switch the provider in prisma/schema.prisma to "postgresql" and use e.g.:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/sokatf?schema=public"
DATABASE_URL="file:./dev.db"

# Admin dashboard credentials (single-admin auth).
ADMIN_EMAIL="admin@sokatf-sarl.com"
ADMIN_PASSWORD="changeme"

# Secret used to sign the admin session cookie. Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="dev-secret-change-me-please-32-chars-min"

# Public site origin allowed to call the API (CORS). The Astro frontend.
WEB_ORIGIN="http://localhost:4321"

# SMTP for outbound lead notifications. Leave blank in dev to log emails
# to the console instead of sending them.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="SOKATF-SARL <no-reply@sokatf-sarl.com>"
# Where new lead notifications are delivered.
LEADS_NOTIFY_TO="contact@sokatf-sarl.com"
